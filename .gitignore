# Ignore CAA folder
/CAA/
/circuit-breakers/*

.env

# Python cache files
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Model and result files
**/*.pkl
/evaluation/results/

# Ignore any new folders not already in the repository
# Whitelist approach - only include specific folders
/*
!/wisent_guard/
!/models/
!/examples/
!/evaluation/
!/dist/
!/wisent_guard.egg-info/

# Don't ignore these files in the root directory
!/.gitignore
!/README.md
!/requirements.txt
!/setup.py
!/LICENSE
!/upload_to_pypi.sh
!/wisent-guard-logo.png
!/.DS_Store

# Make sure evaluation directory exists but ignore the results subdirectory
!/evaluation/